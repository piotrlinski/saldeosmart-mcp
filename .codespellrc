[codespell]
# Skip generated, vendored, and binary content.
skip = .git,.venv,.mypy_cache,.pytest_cache,.ruff_cache,uv.lock,.temp,site,_site_check,*.min.css,*.min.js,*.svg
# Polish words / accounting jargon that codespell flags as typos.
# Extend as new false positives appear.
ignore-words-list = nin,wirh,saldeo,brainshare,nip,pesel,zus
quiet-level = 2
