# SaldeoSMART MCP server — environment variables.
# Copy to `.env` (which is gitignored) and fill in real values.
#
# Token generation: in SaldeoSMART go to Konfiguracja → Konto → API → Generuj
# token. Only biuro-rachunkowe (accounting-firm) accounts can generate tokens;
# end-client accounts cannot. On some plans you must email api@saldeosmart.pl
# first to enable API access.

# Required ----------------------------------------------------------------------

SALDEO_USERNAME=your-login
SALDEO_API_TOKEN=replace-with-token-from-saldeo-settings

# Optional ----------------------------------------------------------------------

# Base URL. Use the test sandbox while developing.
# SALDEO_BASE_URL=https://saldeo.brainshare.pl
# SALDEO_BASE_URL=https://saldeo-test.brainshare.pl

# httpx request timeout in seconds (default: 30).
# SALDEO_TIMEOUT=30

# Logging — see README "Logs" section.
# SALDEO_LOG_DIR=/var/log/saldeosmart
# SALDEO_LOG_LEVEL=INFO
# SALDEO_LOG_RETENTION_DAYS=7
